# PayGlocal initiate endpoint. Keep prod until you move to production credentials.
PAYGLOCAL_INITIATE_URL=https://api.prod.payglocal.in/gl/v1/payments/initiate/paycollect

# Gateway currency used in the actual PayGlocal request.
PAYGLOCAL_TXN_CURRENCY=USD
PAYGLOCAL_STANDING_TYPE=FIXED
