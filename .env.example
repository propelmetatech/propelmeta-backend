PAYGLOCAL_YEARLY_START_DATE=20260401

HOST=0.0.0.0
PORT=3001
ALLOWED_ORIGIN=https://propelmetatech.com
SUCCESS_REDIRECT_URL=https://propelmetatech.com/health
FAILURE_REDIRECT_URL=https://propelmetatech.com/health

# File-backed persistence. Good for a single deployed instance when you do not want a DB yet.
TRANSACTION_STORE_PATH=./data/subscriptions.json
VERIFY_CALLBACK_SIGNATURE=true
MAX_BODY_SIZE_BYTES=1048576
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
